<Application x:Class="PhotoViewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup">
    <Application.Resources>
        <!-- Default theme resources (will be overridden by ThemeManager) -->
        <SolidColorBrush x:Key="WindowBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ControlBackground" Color="#F5F5F5" />
        <SolidColorBrush x:Key="TextForeground" Color="#000000" />
        <SolidColorBrush x:Key="BorderBrush" Color="#DCDCDC" />
        <SolidColorBrush x:Key="MenuBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ListItemHover" Color="#F0F0F0" />
        
        <!-- Default scrollbar colors -->
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#C8C8C8" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#DCDCDC" />
    </Application.Resources>
</Application>