<Window x:Class="PhotoViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:viewModels="clr-namespace:PhotoViewer.ViewModels"
        xmlns:models="clr-namespace:PhotoViewer.Models"
        xmlns:selectors="clr-namespace:PhotoViewer.Selectors"
        xmlns:controls="clr-namespace:PhotoViewer.Controls"
        xmlns:converters="clr-namespace:PhotoViewer.Converters"
        mc:Ignorable="d"
        Title="PhotoViewer Gallery" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Background="{DynamicResource WindowBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="5" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <converters:ImagePathToThumbnailConverter x:Key="ImagePathToThumbnailConverter" />

        <!-- Global ComboBoxItem style for dark mode popup support -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ListItemHover}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Override system colors for ComboBox popup -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{DynamicResource {x:Static SystemColors.WindowColorKey}}" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{DynamicResource {x:Static SystemColors.WindowTextColorKey}}" />

        <!-- Theme-aware ComboBox style -->
        <Style x:Key="ThemeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2"
                                          Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <Path x:Name="Arrow" Fill="{DynamicResource TextForeground}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"
                                                  Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="5,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextElement.Foreground="{DynamicResource TextForeground}" />
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Placeholder Icons -->
        <Path x:Key="IconFolder" x:Shared="False" Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{DynamicResource TextForeground}" />
        <Path x:Key="IconOneDrive" x:Shared="False" Data="M5.5,6.5A2,2 0 0,1 7.5,4.5A2,2 0 0,1 9.5,6.5A2,2 0 0,1 7.5,8.5A2,2 0 0,1 5.5,6.5M10.5,10.5A2,2 0 0,1 12.5,8.5A2,2 0 0,1 14.5,10.5A2,2 0 0,1 12.5,12.5A2,2 0 0,1 10.5,10.5M2,19.5V10.5A2,2 0 0,1 4,8.5H5.5V10.5H4V19.5H12.5V18H14.5V19.5A2,2 0 0,1 12.5,21.5H4A2,2 0 0,1 2,19.5M19,13A4,4 0 0,0 15,17H15.67A3.5,3.5 0 0,0 19,20.5A3.5,3.5 0 0,0 22.5,17A3.5,3.5 0 0,0 19,13.5C18.9,13.5 18.79,13.5 18.69,13.55A4,4 0 0,0 19,13Z" Fill="{DynamicResource TextForeground}" />
        <Path x:Key="IconGoogleDrive" x:Shared="False" Data="M9.2,3.45L15.8,14.29L12.75,19.5L2.5,19.5L5.8,13.79L9.2,3.45M10.5,0L4,11.25L1,19.5H14L18,12.75L10.5,0Z M15.17,15L18.5,9L23,16.5L19.67,22.5H13.42L15.17,15Z" Fill="{DynamicResource TextForeground}" />
        <Path x:Key="IconRecent" x:Shared="False" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M16.2,16.2L11,13V7H12.5V12.2L17,14.9L16.2,16.2Z" Fill="{DynamicResource TextForeground}" />
        <Path x:Key="IconGallery" x:Shared="False" Data="M4,4H10V10H4V4M14,4H20V10H14V4M4,14H10V20H4V14M14,14H20V20H14V14Z" Fill="{DynamicResource TextForeground}" />
        <Path x:Key="IconHeart" x:Shared="False" Data="M12,21.35l-1.45-1.32C5.4,15.36 2,12.28 2,8.5 2,5.42 4.42,3 7.5,3c1.74,0 3.41,0.81 4.5,2.09C13.09,3.81 14.76,3 16.5,3 19.58,3 22,5.42 22,8.5c0,3.78 -3.4,6.86 -8.55,11.54L12,21.35z" Fill="{DynamicResource TextForeground}" Stretch="Uniform" Width="20" Height="20" />
        <Path x:Key="IconHeartOutline" x:Shared="False" Data="M16.5,3c-1.74,0 -3.41,0.81 -4.5,2.09C10.91,3.81 9.24,3 7.5,3 4.42,3 2,5.42 2,8.5c0,3.78 3.4,6.86 8.55,11.54L12,21.35l1.45-1.32C18.6,15.36 22,12.28 22,8.5 22,5.42 19.58,3 16.5,3zm-4.4,15.55l-0.1,0.1 -0.1-0.1C7.14,14.24 4,11.39 4,8.5 4,6.5 5.5,5 7.5,5c1.54,0 3.04,0.99 3.56,2.36h1.87C13.46,5.99 14.96,5 16.5,5c2,0 3.5,1.5 3.5,3.5 0,2.89 -3.14,5.74 -7.9,10.05z" Fill="{DynamicResource TextForeground}" Stretch="Uniform" Width="20" Height="20" />
        <Path x:Key="IconSettings" x:Shared="False" Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" Fill="{DynamicResource TextForeground}" />

        <!-- Menu Styles -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource MenuBackground}" />
        </Style>
        
        <!-- ScrollBar Styles -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{DynamicResource ControlBackground}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="{DynamicResource BorderBrush}" CornerRadius="5" Margin="1,0,1,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Data Templates for source types -->
        <DataTemplate x:Key="FolderSourceTemplate">
            <StackPanel Orientation="Horizontal">
                <ContentPresenter Content="{StaticResource IconFolder}" Width="16" Height="16" Margin="0,0,8,0" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontSize="10" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="OneDriveSourceTemplate" DataType="{x:Type viewModels:OneDriveSourceViewModel}">
            <StackPanel Orientation="Horizontal">
                <ContentPresenter Content="{StaticResource IconOneDrive}" Width="16" Height="16" Margin="0,0,8,0" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontSize="10" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="GoogleDriveSourceTemplate" DataType="{x:Type viewModels:GoogleDriveSourceViewModel}">
            <StackPanel Orientation="Horizontal">
                <ContentPresenter Content="{StaticResource IconGoogleDrive}" Width="16" Height="16" Margin="0,0,8,0" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontSize="10" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="GenericSourceTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#10084;" Foreground="{DynamicResource TextForeground}" FontFamily="Segoe UI Symbol" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontSize="10" Foreground="{DynamicResource TextForeground}" Opacity="0.5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayName}" Value="Recently Viewed">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="GallerySourceTemplate">
            <StackPanel Orientation="Horizontal">
                <ContentPresenter Content="{StaticResource IconGallery}" Width="16" Height="16" Margin="0,0,8,0" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                           FontSize="10" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
            </StackPanel>
        </DataTemplate>

        <selectors:SourceTemplateSelector x:Key="SourceSelector"
                                          FolderTemplate="{StaticResource FolderSourceTemplate}"
                                          OneDriveTemplate="{StaticResource OneDriveSourceTemplate}"
                                          GoogleDriveTemplate="{StaticResource GoogleDriveSourceTemplate}"
                                          GalleryTemplate="{StaticResource GallerySourceTemplate}"
                                          DefaultTemplate="{StaticResource GenericSourceTemplate}" />

    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{DynamicResource ControlBackground}" Height="32">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Window Title -->
                <TextBlock Grid.Column="0" Text="PhotoViewer Gallery" 
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           FontSize="13" Foreground="{DynamicResource TextForeground}" />
                
                <!-- Window Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Settings Button -->
                    <Button Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding OpenSettingsCommand}" ToolTip="Settings">
                        <Viewbox Width="18" Height="18" Margin="2">
                            <ContentPresenter Content="{StaticResource IconSettings}" />
                        </Viewbox>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemHover}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Minimize Button -->
                    <Button Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="MinimizeButton_Click" ToolTip="Minimize">
                        <Path Data="M6,8 L18,8" Stroke="{DynamicResource TextForeground}" StrokeThickness="1" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemHover}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Maximize/Restore Button -->
                    <Button x:Name="MaximizeButton" Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="MaximizeButton_Click" ToolTip="Maximize">
                        <Path Data="M6,6 L18,6 L18,18 L6,18 Z" Stroke="{DynamicResource TextForeground}" StrokeThickness="1" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemHover}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Close Button -->
                    <Button Width="46" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="CloseButton_Click" ToolTip="Close">
                        <Path Data="M8,8 L16,16 M16,8 L8,16" Stroke="{DynamicResource TextForeground}" StrokeThickness="1" />
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemHover}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Menu Bar -->
            <Menu Grid.Row="0" Background="{DynamicResource MenuBackground}">
                <MenuItem Header="File" Foreground="{DynamicResource TextForeground}">
                    <MenuItem Header="_Open Image(s)..." Command="{Binding OpenImageCommand}" />
                    <Separator />
                    <MenuItem Header="_Save Layout..." Command="{Binding SaveLayoutCommand}" IsEnabled="False" />
                    <MenuItem Header="_Load Layout..." Command="{Binding LoadLayoutCommand}" IsEnabled="False" />
                    <Separator />
                    <MenuItem Header="E_xit" Click="Exit_Click" />
                </MenuItem>
                <MenuItem Header="Sources" Foreground="{DynamicResource TextForeground}">
                    <MenuItem Header="Add Local Folder..." Command="{Binding AddLocalFolderCommand}" />
                    <MenuItem Header="Add OneDrive Account..." Command="{Binding AddOneDriveAccountCommand}" />
                    <MenuItem Header="Add Google Drive Account..." Command="{Binding AddGoogleDriveAccountCommand}" />
                    <MenuItem Header="Sync iCloud Photos..." IsEnabled="False" />
                    <MenuItem Header="Import from Phone..." IsEnabled="False" />
                </MenuItem>
            </Menu>

            <Grid Grid.Row="1" Background="{DynamicResource ControlBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150" MaxWidth="400" /> <!-- Source Navigation Pane -->
                <ColumnDefinition Width="Auto" /> <!-- GridSplitter -->
                <ColumnDefinition Width="*" />    <!-- Photo Grid -->
            </Grid.ColumnDefinitions>

            <!-- Source Navigation Pane -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource ControlBackground}">
                <StackPanel>
                    <!-- Collections: Gallery, Favorites, Recently Viewed -->
                    <ListBox x:Name="CollectionListBox"
                             ItemsSource="{Binding CollectionSources}"
                             SelectedItem="{Binding SelectedSource}"
                             BorderThickness="0" Background="Transparent"
                             ItemTemplateSelector="{StaticResource SourceSelector}"
                             Foreground="{DynamicResource TextForeground}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,4,8,4" />
                                <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Divider Line -->
                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="12,4,12,4" />

                    <!-- User Sources: Folder trees + Cloud accounts -->
                    <TreeView x:Name="SourceTreeView"
                              ItemsSource="{Binding UserSources}"
                              BorderThickness="0" Background="Transparent"
                              Foreground="{DynamicResource TextForeground}"
                              SelectedItemChanged="SourceTreeView_SelectedItemChanged">
                        <TreeView.Resources>
                            <!-- Template for non-folder sources (OneDrive, Google Drive) -->
                            <HierarchicalDataTemplate DataType="{x:Type viewModels:SourceItemViewModel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ContentPresenter Width="18" Height="18" Margin="0,0,8,0">
                                            <ContentPresenter.Style>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Content" Value="{StaticResource IconFolder}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Provider}" Value="{x:Null}">
                                                            <Setter Property="Content" Value="{StaticResource IconFolder}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ContentPresenter.Style>
                                        </ContentPresenter>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="13" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="8,0,0,0"
                                               FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
                                </Grid>
                            </HierarchicalDataTemplate>

                            <!-- Template for folder source root -->
                            <HierarchicalDataTemplate DataType="{x:Type viewModels:FolderSourceViewModel}"
                                                      ItemsSource="{Binding Root.SubFolders}">
                                <DockPanel LastChildFill="True">
                                    <!-- Right-aligned chevron — click to expand/collapse -->
                                    <Path x:Name="RootChevron" DockPanel.Dock="Right"
                                          Width="14" Height="10" Margin="4,0,6,0"
                                          Data="M 0 0 L 7 7 L 14 0 L 10 0 L 7 3 L 4 0 Z"
                                          Fill="{DynamicResource TextForeground}"
                                          VerticalAlignment="Center"
                                          MouseLeftButtonDown="Chevron_MouseLeftButtonDown" />
                                    <!-- Left: folder icon and name -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ContentPresenter Content="{StaticResource IconFolder}" Width="18" Height="18" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                   FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
                                    </StackPanel>
                                </DockPanel>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Root.HasSubFolders}" Value="False">
                                        <Setter TargetName="RootChevron" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <!-- When expanded, point up -->
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TreeViewItem}}, Path=IsExpanded}" Value="True">
                                        <Setter TargetName="RootChevron" Property="Data" Value="M 0 7 L 7 0 L 14 7 L 10 7 L 7 4 L 4 7 Z" />
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>

                            <!-- Template for subfolder nodes -->
                            <HierarchicalDataTemplate DataType="{x:Type models:FolderNode}"
                                                      ItemsSource="{Binding SubFolders}">
                                <DockPanel LastChildFill="True">
                                    <!-- Right-aligned chevron — click to expand/collapse -->
                                    <Path x:Name="Chevron" DockPanel.Dock="Right"
                                          Width="14" Height="10" Margin="4,0,6,0"
                                          Data="M 0 0 L 7 7 L 14 0 L 10 0 L 7 3 L 4 0 Z"
                                          Fill="{DynamicResource TextForeground}"
                                          VerticalAlignment="Center"
                                          MouseLeftButtonDown="Chevron_MouseLeftButtonDown" />
                                    <!-- Left: folder icon, name, count -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ContentPresenter Content="{StaticResource IconFolder}" Width="16" Height="16" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" />
                                        <TextBlock Text="{Binding PhotoCount}" VerticalAlignment="Center" Margin="6,0,0,0"
                                                   FontSize="11" Foreground="{DynamicResource TextForeground}" Opacity="0.5" />
                                    </StackPanel>
                                </DockPanel>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasSubFolders}" Value="False">
                                        <Setter TargetName="Chevron" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <!-- When expanded, point up — bind to TreeViewItem.IsExpanded for reliable updates -->
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TreeViewItem}}, Path=IsExpanded}" Value="True">
                                        <Setter TargetName="Chevron" Property="Data" Value="M 0 7 L 7 0 L 14 7 L 10 7 L 7 4 L 4 7 Z" />
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>

                                <HierarchicalDataTemplate.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TreeViewItem">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition />
                                                        </Grid.RowDefinitions>
                                                        <Border x:Name="HeaderBorder" Grid.Row="0"
                                                                Background="Transparent"
                                                                CornerRadius="4" Padding="4,3"
                                                                HorizontalAlignment="Stretch">
                                                            <ContentPresenter x:Name="PART_Header"
                                                                              ContentSource="Header"
                                                                              HorizontalAlignment="Stretch" />
                                                        </Border>
                                                        <ItemsPresenter x:Name="ItemsHost"
                                                                        Grid.Row="1"
                                                                        Margin="18,0,0,0"
                                                                        Visibility="Collapsed" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsExpanded" Value="True">
                                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="HeaderBorder" Property="Background"
                                                                    Value="{DynamicResource ListItemHover}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="HeaderBorder" Property="Background"
                                                                    Value="{DynamicResource ListItemHover}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </HierarchicalDataTemplate.ItemContainerStyle>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition />
                                                </Grid.RowDefinitions>
                                                <Border x:Name="HeaderBorder" Grid.Row="0"
                                                        Background="Transparent"
                                                        CornerRadius="4" Padding="4,3"
                                                        HorizontalAlignment="Stretch">
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="Stretch" />
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost"
                                                                Grid.Row="1"
                                                                Margin="18,0,0,0"
                                                                Visibility="Collapsed" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="True">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HeaderBorder" Property="Background"
                                                            Value="{DynamicResource ListItemHover}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="HeaderBorder" Property="Background"
                                                            Value="{DynamicResource ListItemHover}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove" Click="RemoveMenuItem_Click" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{DynamicResource BorderBrush}" />

            <!-- Photo Grid -->
            <DockPanel Grid.Column="2">
                <!-- Toolbar for Sorting and Filtering -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5" Background="{DynamicResource ControlBackground}">
                    <TextBlock Text="Sort by:" VerticalAlignment="Center" Margin="5,0,5,0" Foreground="{DynamicResource TextForeground}"/>
                    <ComboBox x:Name="SortByComboBox"
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortOption}"
                        Width="120"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource ThemeComboBoxStyle}"/>

                    <TextBlock Text="Order:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="{DynamicResource TextForeground}"/>
                    <ComboBox x:Name="OrderComboBox"
                        ItemsSource="{Binding SortDirections}"
                        SelectedItem="{Binding SelectedSortDirection}"
                        Width="100"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource ThemeComboBoxStyle}"/>

                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="{DynamicResource TextForeground}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" VerticalContentAlignment="Center"
                             Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource TextForeground}"
                             BorderBrush="{DynamicResource BorderBrush}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding PhotosView}" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="PhotoListBox_SelectionChanged"
                         Background="{DynamicResource ControlBackground}"
                         Margin="24,0,24,0"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:JustifiedWrapPanel TargetRowHeight="180" ItemSpacing="5" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:PhotoItemViewModel}">
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" ToolTip="{Binding Photo.FilePath}">
                                <Grid Cursor="Hand">
                                    <Image Source="{Binding Photo.FilePath, Converter={StaticResource ImagePathToThumbnailConverter}, IsAsync=True}" Stretch="UniformToFill" />

                                    <!-- Favorite Button -->
                                    <Button Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Width="36" Height="36" Margin="0,10,10,0"
                                            Background="{DynamicResource ControlBackground}" BorderThickness="0"
                                            FontFamily="Segoe UI Symbol" FontSize="20"
                                            Padding="0"
                                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Content" Value="&#9825;" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Content" Value="&#10084;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
        </Grid>
    </Grid>
</Window>