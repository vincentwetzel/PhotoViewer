<UserControl x:Class="PhotoViewer.Controls.PhotoThumbnail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:PhotoViewer.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="150"
             Cursor="Hand">
    <UserControl.Resources>
        <converters:ImagePathToThumbnailConverter x:Key="ImagePathToThumbnailConverter" />
    </UserControl.Resources>
    <Grid>
        <Image Source="{Binding ImagePath, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ImagePathToThumbnailConverter}, IsAsync=True}" Stretch="UniformToFill" />
    </Grid>
</UserControl>